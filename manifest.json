{
  "manifest_version": 3,
  "name": "KillShort",
  "version": "1.1.0",
  "description": "Blocks Instagram Reels and YouTube Shorts, hides Shorts tabs, and removes short-form recommendations.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "*://*.youtube.com/*",
    "*://*.instagram.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*"
      ],
      "js": [
        "content/youtube.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://*.instagram.com/*"
      ],
      "js": [
        "content/instagram.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "KillShort",
    "default_popup": "popup/popup.html"
  }
}